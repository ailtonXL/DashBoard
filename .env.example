# Django
SECRET_KEY=troque-por-uma-chave-secreta-forte
DEBUG=False
ALLOWED_HOSTS=dashboard-vwob.onrender.com,localhost,127.0.0.1

# CSRF
CSRF_TRUSTED_ORIGINS=https://dashboard-vwob.onrender.com,http://127.0.0.1:8000,http://localhost:8000

# Chave de criptografia dos campos sensíveis (gerar com Fernet)
# Exemplo de geração:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=COLOQUE_A_CHAVE_FERNET_AQUI
# idealmente, a chave deve ser mantida em segredo e não deve ser compartilhada publicamente.
# Banco de dados (opcional: para Postgres em produção)
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=

# Segurança HTTPS em produção
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
